# 复制本文件为 .env 后填写真实值（.env 勿提交到 Git）
# 必须与 manage.py 在同一目录，例如：.../my_project/.env
# 填好后执行：pip install -r requirements.txt && python manage.py check_env

MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

SECRET_KEY=
DJANGO_DEBUG=0
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=
